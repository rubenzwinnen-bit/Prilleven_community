# Optional: input/output paths (defaults shown)
INPUT_DIR=/Users/anneleenplettinx/Desktop/RAG content
OUTPUT_DIR=/Users/anneleenplettinx/Desktop/RAG content/chunks

# ===== Ingestion script (ingest.js) =====
# Voyage AI — for embeddings. Free tier 200M tokens.
# Get one at: https://dash.voyageai.com/
